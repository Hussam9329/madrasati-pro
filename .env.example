# Supabase PostgreSQL - Pooled connection (for app queries via Prisma)
# Use Transaction mode (port 6543) with pgbouncer
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=20"

# Supabase PostgreSQL - Direct connection (for Prisma migrations)
# Use Session mode (port 5432) or direct DB host
DIRECT_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres"

# JWT Secret for auth sessions
JWT_SECRET="madrasati-secret-key-2024-marina-school"

# Node Environment
NODE_ENV="development"
