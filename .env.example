# Supabase REST API settings used by the application at runtime
# Get NEXT_PUBLIC_SUPABASE_URL from Supabase > Project Settings > API > Project URL
NEXT_PUBLIC_SUPABASE_URL="https://YOUR-PROJECT-REF.supabase.co"

# Use the Service Role key only on the server / Vercel environment variables.
# Never expose it in browser code or public repositories.
SUPABASE_SERVICE_ROLE_KEY="YOUR-SUPABASE-SERVICE-ROLE-KEY"

# JWT Secret for auth sessions
JWT_SECRET="madrasati-secret-key-2024-marina-school"

# Node Environment
NODE_ENV="development"

# Optional: direct PostgreSQL URLs if you later add Prisma migrations again.
# The current project code uses Supabase REST through the variables above.
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=20"
DIRECT_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres"
