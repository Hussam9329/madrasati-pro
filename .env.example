# ===========================================
# مدرستي Pro - Environment Variables
# ===========================================
# انسخ هذا الملف إلى .env واملأ القيم الحقيقية
# cp .env.example .env
# ===========================================

# قاعدة البيانات (PostgreSQL)
# مثال لـ Neon: postgresql://user:password@host/database?sslmode=require
DATABASE_URL=

# مفتاح JWT (يجب أن يكون طويلاً وعشوائياً)
# يمكن توليده: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=

# رابط التطبيق (اختياري)
NEXT_PUBLIC_APP_URL=http://localhost:3000
