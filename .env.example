# ===========================================
# مدرستي Pro - Environment Variables
# ===========================================
# انسخ هذا الملف إلى .env.local واملأ القيم الحقيقية
# cp .env.example .env.local
#
# ⚠️ لا ترفع ملف .env أو .env.local إلى GitHub أبداً!
# ===========================================

# قاعدة البيانات (PostgreSQL)
# مثال لـ Neon: postgresql://user:password@host/database?sslmode=require
DATABASE_URL=

# مفتاح JWT (إلزامي — يجب أن يكون 32 حرفاً على الأقل)
# توليد مفتاح: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=

# رابط التطبيق (اختياري — يُستخدم للروابط المطلقة)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# كلمة مرور المدير الافتراضية (اختياري — يُستخدم في seed فقط)
# إذا لم يُحدَّد، ستكون كلمة المرور الافتراضية: admin123
# ⚠️ غيّرها فوراً بعد التثبيت الأول!
ADMIN_PASSWORD=

# بيئة التشغيل
NODE_ENV=development
