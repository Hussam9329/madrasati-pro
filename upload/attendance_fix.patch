+        classLevel: student.section?.class?.level ?? null,
+        scheduleId: null,
+        dayOfWeek: null,
+        startTime: null,
+        endTime: null,
+        subjectId: null,
+        subjectName: null,
+        teacherId: null,
+        teacherName: null,
+        createdAt: new Date(date),
+        isComputed: true,
+      });
+    }
+  }
+
+  return computedRecords.filter((record) => matchesAttendanceListFilter(record, filter));
+}
