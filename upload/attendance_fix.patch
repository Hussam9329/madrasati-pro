+function getAttendanceDateKey(value: string | Date): string | null {
+  const date = normalizeDateOnly(value);
+  return date ? formatDateKey(date) : null;
+}
+
+function getStartOfDay(value: Date): Date {
+  return new Date(
+    value.getFullYear(),
+    value.getMonth(),
+    value.getDate(),
+    0,
+    0,
+    0,
+    0,
+  );
+}
+
+function getEndOfDayExclusive(value: Date): Date {
+  const end = getStartOfDay(value);
+  end.setDate(end.getDate() + 1);
+  return end;
+}
+
+function getComputedAbsenceBounds(filter: AttendanceFilter): {
+  start: Date;
+  end: Date;
+} | null {
+  const today = normalizeDateOnly(new Date());
+  if (!today) return null;
+
+  const todayStart = getStartOfDay(today);
+  let start: Date | null = null;
+  let end: Date | null = null;
+
+  if (filter.date) {
+    const date = normalizeDateOnly(filter.date);
+    if (!date) return null;
+    start = getStartOfDay(date);
+    end = getStartOfDay(date);
+  } else if (filter.fromDate || filter.toDate) {
+    const from = filter.fromDate ? normalizeDateOnly(filter.fromDate) : null;
+    const to = filter.toDate ? normalizeDateOnly(filter.toDate) : null;
+
+    if (filter.fromDate && !from) return null;
+    if (filter.toDate && !to) return null;
+
+    start = getStartOfDay(from ?? to ?? todayStart);
+    end = getStartOfDay(to ?? todayStart);
+  }
+
+  if (!start || !end) {
+    return null;
+  }
+
+  if (start.getTime() > todayStart.getTime()) {
+    return null;
+  }
+
+  if (end.getTime() > todayStart.getTime()) {
+    end = todayStart;
+  }
+
+  if (end.getTime() < start.getTime()) {
+    return null;
+  }
+
+  return { start, end };
+}
+
+async function getComputedAbsenceDates(filter: AttendanceFilter): Promise<Date[]> {
+  const bounds = getComputedAbsenceBounds(filter);
+  if (!bounds) return [];
+
+  const settings = await getSchoolSettings();
+  const dates: Date[] = [];
+  const cursor = new Date(bounds.start);
+
+  for (let i = 0; cursor.getTime() <= bounds.end.getTime() && i < 370; i += 1) {
+    if (!isConfiguredHoliday(cursor, settings)) {
+      dates.push(new Date(cursor));
+    }
+    cursor.setDate(cursor.getDate() + 1);
+  }
+
+  return dates;
+}
+
+function shouldIncludeComputedAbsences(filter: AttendanceFilter): boolean {
+  if (filter.status && filter.status !== "absent") {
+    return false;
+  }
+
+  if (filter.source || filter.scheduleId || filter.subjectId || filter.teacherId) {
+    return false;
+  }
+
+  if (filter.hasCheckIn === "yes" || filter.hasCheckOut === "yes" || filter.missingCheckOut === "yes") {
+    return false;
+  }
+
+  return Boolean(filter.date || filter.fromDate || filter.toDate);
+}
+
+async function getStudentsForComputedAbsences(
+  filter: AttendanceFilter,
+): Promise<any[]> {
+  const studentWhere: Prisma.StudentWhereInput = {
+    status: "active",
+  };
+
+  if (filter.studentId) {
+    studentWhere.id = filter.studentId;
+  }
+
+  let classSectionIds: string[] | null = null;
+
+  if (filter.classId) {
+    const sections = await db.section.findMany({
+      where: { classId: filter.classId },
+      select: { id: true },
+    });
+    classSectionIds = sections.map((section: { id: string }) => section.id);
+
+    if (classSectionIds.length === 0) {
+      return [];
+    }
+  }
+
+  if (filter.sectionId) {
+    if (classSectionIds && !classSectionIds.includes(filter.sectionId)) {
+      return [];
+    }
+    studentWhere.sectionId = filter.sectionId;
+  } else if (classSectionIds) {
+    studentWhere.sectionId = { in: classSectionIds };
+  }
+
+  return db.student.findMany({
+    where: studentWhere,
+    include: {
+      section: {
+        include: {
+          class: true,
+        },
+      },
+    },
+    orderBy: [
+      { fullName: "asc" },
+    ],
+  });
+}
+
+async function getRecordedAttendanceKeysForComputedAbsences(
+  filter: AttendanceFilter,
+  dates: Date[],
+): Promise<Set<string>> {
+  const keys = new Set<string>();
+  if (dates.length === 0) return keys;
+
+  const sortedDates = dates.slice().sort((a, b) => a.getTime() - b.getTime());
+  const where: Prisma.AttendanceRecordWhereInput = {
+    date: {
+      gte: getStartOfDay(sortedDates[0]),
+      lt: getEndOfDayExclusive(sortedDates[sortedDates.length - 1]),
+    },
+  };
+
+  if (filter.studentId) {
+    where.studentId = filter.studentId;
+  }
+
+  const records = await db.attendanceRecord.findMany({ where });
+
+  for (const record of records) {
+    const key = getAttendanceDateKey(record.date);
+    if (!key || !record.studentId) continue;
+    keys.add(`${record.studentId}:${key}`);
+  }
+
+  return keys;
+}
+
+async function buildComputedAbsenceRecords(
+  filter: AttendanceFilter,
+): Promise<AttendanceListItem[]> {
+  if (!shouldIncludeComputedAbsences(filter)) {
+    return [];
+  }
+
+  const dates = await getComputedAbsenceDates(filter);
+  if (dates.length === 0) return [];
+
+  const [students, recordedKeys] = await Promise.all([
+    getStudentsForComputedAbsences(filter),
+    getRecordedAttendanceKeysForComputedAbsences(filter, dates),
+  ]);
+
+  const computedRecords: AttendanceListItem[] = [];
+
+  for (const student of students) {
+    for (const date of dates) {
+      const dateKey = formatDateKey(date);
+      const key = `${student.id}:${dateKey}`;
+
+      if (recordedKeys.has(key)) {
