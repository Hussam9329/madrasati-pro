generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Admin {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String
  isRoot       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("admins")
}

model Subject {
  id          String  @id @default(cuid())
  name        String  @unique
  description String?
  isActive    Boolean @default(true)

  teacherSubjects TeacherSubject[]
  classSubjects   ClassSubject[]
  grades          Grade[]
  schedules       Schedule[]
  exams           Exam[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("subjects")
}

model SchoolClass {
  id          String  @id @default(cuid())
  name        String
  level       String?
  description String?
  isActive    Boolean @default(true)

  sections      Section[]
  classSubjects ClassSubject[]
  feeSettings   ClassFeeSetting[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([name, level])
  @@map("school_classes")
}

model Section {
  id          String  @id @default(cuid())
  name        String
  capacity    Int?
  description String?
  isActive    Boolean @default(true)

  classId String
  class   SchoolClass @relation(fields: [classId], references: [id], onDelete: Cascade)

  students        Student[]
  schedules       Schedule[]
  teacherSections TeacherSection[]
  exams           Exam[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([classId, name])
  @@index([classId])
  @@map("sections")
}

model Teacher {
  id        String  @id @default(cuid())
  fullName  String
  phone     String?
  email     String?
  address   String?
  specialty String?
  salary    Float?
  notes     String?
  isActive  Boolean @default(true)

  teacherSubjects TeacherSubject[]
  teacherSections TeacherSection[]
  schedules       Schedule[]
  grades          Grade[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([fullName])
  @@map("teachers")
}

model TeacherSubject {
  id String @id @default(cuid())

  teacherId String
  teacher   Teacher @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  subjectId String
  subject   Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([teacherId, subjectId])
  @@index([teacherId])
  @@index([subjectId])
  @@map("teacher_subjects")
}

model TeacherSection {
  id String @id @default(cuid())

  teacherId String
  teacher   Teacher @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  sectionId String
  section   Section @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([teacherId, sectionId])
  @@index([teacherId])
  @@index([sectionId])
  @@map("teacher_sections")
}

model ClassSubject {
  id String @id @default(cuid())

  classId String
  class   SchoolClass @relation(fields: [classId], references: [id], onDelete: Cascade)

  subjectId String
  subject   Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([classId, subjectId])
  @@index([classId])
  @@index([subjectId])
  @@map("class_subjects")
}

model Student {
  id             String  @id @default(cuid())
  fullName       String
  studentCode    String? @unique
  gender         String?
  birthDate      DateTime?
  phone          String?
  guardianName   String?
  guardianPhone  String?
  address        String?
  enrollmentDate DateTime @default(now())
  status         String   @default("active")
  notes          String?

  sectionId String?
  section   Section? @relation(fields: [sectionId], references: [id], onDelete: SetNull)

  attendanceRecords AttendanceRecord[]
  grades            Grade[]
  payments          Payment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([fullName])
  @@index([sectionId])
  @@map("students")
}

model Schedule {
  id        String  @id @default(cuid())
  dayOfWeek String
  startTime String
  endTime   String
  room      String?
  notes     String?
  isActive  Boolean @default(true)

  sectionId String
  section   Section @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  subjectId String
  subject   Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  teacherId String
  teacher   Teacher @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  attendanceRecords AttendanceRecord[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([sectionId])
  @@index([subjectId])
  @@index([teacherId])
  @@index([dayOfWeek])
  @@map("schedules")
}

model AttendanceRecord {
  id     String  @id @default(cuid())
  date   DateTime
  mode   String  @default("check-in")
  status String  @default("present")
  notes  String?
  checkInAt  DateTime?
  checkOutAt DateTime?
  source     String? @default("manual")

  studentId String
  student   Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  scheduleId String?
  schedule   Schedule? @relation(fields: [scheduleId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([studentId, date])
  @@index([studentId])
  @@index([scheduleId])
  @@index([date])
  @@map("attendance_records")
}

model Exam {
  id        String   @id @default(cuid())
  name      String
  type      String
  date      DateTime @default(now())
  maxScore  Float    @default(100)
  passScore Float    @default(50)
  failScore Float?
  notes     String?

  subjectId String
  subject   Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  sectionId String
  section   Section @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  grades Grade[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([subjectId])
  @@index([sectionId])
  @@map("exams")
}

model Grade {
  id        String   @id @default(cuid())
  title     String
  score     Float
  maxScore  Float    @default(100)
  examType  String   @default("monthly")
  term      String   @default("first")
  date      DateTime @default(now())
  notes     String?
  weight          Float?
  assessmentGroup String?
  isReviewed      Boolean  @default(false)
  warningLevel    String?

  studentId String
  student   Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  subjectId String
  subject   Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  teacherId String?
  teacher   Teacher? @relation(fields: [teacherId], references: [id], onDelete: SetNull)

  examId String?
  exam   Exam? @relation(fields: [examId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([examId, studentId])
  @@index([studentId])
  @@index([subjectId])
  @@index([teacherId])
  @@index([examId])
  @@map("grades")
}

model ClassFeeSetting {
  id           String   @id @default(cuid())
  classId      String
  class        SchoolClass @relation(fields: [classId], references: [id], onDelete: Cascade)
  amount       Float
  academicYear String?
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([classId, academicYear])
  @@index([classId])
  @@map("class_fee_settings")
}

model Payment {
  id              String    @id @default(cuid())
  feeTitle        String
  feeType         String    @default("tuition")
  amount          Float
  status          String    @default("paid")
  method          String    @default("cash")
  academicYear    String?
  dueDate         DateTime?
  paidAt          DateTime?
  notes           String?
  originalAmount  Float?
  discountAmount  Float     @default(0)
  discountPercent Float?
  discountReason  String?
  discountNotes   String?
  finalAmount     Float?
  remainingAmount Float?
  receiptNumber   String?   @unique

  studentId String
  student   Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([studentId])
  @@index([status])
  @@index([feeType])
  @@map("payments")
}
