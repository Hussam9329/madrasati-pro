generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== SCHOOL (مدرستي - Single School) ====================
model School {
  id              String   @id @default(cuid())
  name            String   @default("مدرستي")
  logo            String?
  address         String?
  phone           String?
  email           String?
  principalName   String?
  academicYear    String   @default("2026-2027")
  schoolType      String   @default("ثانوية اعتيادية")
  shiftType       String   @default("صباحي")
  startTime       String   @default("08:00")
  endTime         String   @default("13:30")
  lateThreshold   Int      @default(10)
  weekendDays     String   @default("5,6")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  students      Student[]
  teachers      Teacher[]
  subjects      Subject[]
  classes       Class[]
  sections      Section[]
  attendance    AttendanceRecord[]
  grades        Grade[]
  feePlans      FeePlan[]
  installments  Installment[]
  scheduleSlots ScheduleSlot[]
}

// ==================== CLASSES & SECTIONS ====================
model Class {
  id        String   @id @default(cuid())
  name      String
  level     String
  stage     String
  branch    String?
  schoolId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  school        School          @relation(fields: [schoolId], references: [id])
  sections      Section[]
  students      Student[]
  subjects      SubjectClass[]
  scheduleSlots ScheduleSlot[]
  teacherAssignments TeacherClass[]
  feePlans      FeePlan[]
  installments  Installment[]
}

model Section {
  id        String   @id @default(cuid())
  name      String
  classId   String
  schoolId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  class    Class    @relation(fields: [classId], references: [id])
  school   School   @relation(fields: [schoolId], references: [id])
  students Student[]
}

// ==================== STUDENTS ====================
model Student {
  id              String   @id @default(cuid())
  studentNumber   String   @unique
  fullName        String
  gender          String   @default("ذكر")
  dateOfBirth     String?
  nationalId      String?
  phone           String?
  address         String?
  photo           String?
  status          String   @default("مستمر")
  qrCode          String?
  cardStatus      String   @default("فعالة")

  classId         String
  sectionId       String
  schoolId        String

  guardianName    String?
  guardianPhone   String?
  guardianRelation String?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  class      Class              @relation(fields: [classId], references: [id])
  section    Section            @relation(fields: [sectionId], references: [id])
  school     School             @relation(fields: [schoolId], references: [id])
  attendance AttendanceRecord[]
  grades     Grade[]
  installments Installment[]
  payments   Payment[]
}

// ==================== TEACHERS ====================
model Teacher {
  id          String   @id @default(cuid())
  fullName    String
  phone       String?
  email       String?
  notes       String?
  status      String   @default("نشط")
  photo       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  schoolId      String
  school        School           @relation(fields: [schoolId], references: [id])
  subjects      TeacherSubject[]
  classes       TeacherClass[]
  scheduleSlots ScheduleSlot[]
}

// ==================== SUBJECTS ====================
model Subject {
  id            String   @id @default(cuid())
  name          String
  code          String   @unique
  type          String   @default("أساسية")
  maxScore      Int      @default(100)
  passScore     Int      @default(50)
  schoolId      String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  school        School           @relation(fields: [schoolId], references: [id])
  teachers      TeacherSubject[]
  classes       SubjectClass[]
  grades        Grade[]
  examTypes     ExamType[]
  scheduleSlots ScheduleSlot[]
}

model TeacherSubject {
  id        String @id @default(cuid())
  teacherId String
  subjectId String

  teacher   Teacher @relation(fields: [teacherId], references: [id])
  subject   Subject @relation(fields: [subjectId], references: [id])

  @@unique([teacherId, subjectId])
}

model SubjectClass {
  id        String @id @default(cuid())
  subjectId String
  classId   String

  subject   Subject @relation(fields: [subjectId], references: [id])
  class     Class   @relation(fields: [classId], references: [id])

  @@unique([subjectId, classId])
}

model TeacherClass {
  id        String  @id @default(cuid())
  teacherId String
  classId   String
  sectionId String?

  teacher   Teacher @relation(fields: [teacherId], references: [id])
  class     Class   @relation(fields: [classId], references: [id])

  @@unique([teacherId, classId])
}

// ==================== EXAM TYPES ====================
model ExamType {
  id         String   @id @default(cuid())
  name       String
  maxScore   Int
  subjectId  String
  createdAt  DateTime @default(now())

  subject    Subject  @relation(fields: [subjectId], references: [id])
  grades     Grade[]
}

// ==================== ATTENDANCE (QR-based) ====================
model AttendanceRecord {
  id          String   @id @default(cuid())
  studentId   String
  schoolId    String
  date        String
  checkIn     String?
  checkOut    String?
  status      String   @default("غائب")
  lateMinutes Int?
  earlyExitReason String?
  earlyExitApproved Boolean?
  modifiedBy  String?
  modifiedAt  DateTime?
  createdAt   DateTime @default(now())

  student     Student  @relation(fields: [studentId], references: [id])
  school      School   @relation(fields: [schoolId], references: [id])

  @@unique([studentId, date])
}

// ==================== GRADES ====================
model Grade {
  id           String   @id @default(cuid())
  studentId    String
  subjectId    String
  examTypeId   String
  schoolId     String
  score        Float?
  status       String   @default("ناقصة")
  approved     Boolean  @default(false)
  approvedBy   String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  student      Student  @relation(fields: [studentId], references: [id])
  subject      Subject  @relation(fields: [subjectId], references: [id])
  examType     ExamType @relation(fields: [examTypeId], references: [id])
  school       School   @relation(fields: [schoolId], references: [id])

  @@unique([studentId, subjectId, examTypeId])
}

// ==================== INSTALLMENTS & PAYMENTS (الأقساط والدفعات) ====================

// Fee Plan - خطة الرسوم لكل صف
model FeePlan {
  id              String   @id @default(cuid())
  name            String                    // اسم الخطة، مثل: القسط الأول، القسط الثاني
  amount          Int                       // المبلغ بالدينار العراقي
  classId         String                    // الصف المرتبط
  schoolId        String
  dueDate         String?                   // تاريخ الاستحقاق
  description     String?                   // وصف اختياري
  sortOrder       Int      @default(0)      // ترتيب الأقساط
  active          Boolean  @default(true)   // مفعل أو لا
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  class           Class        @relation(fields: [classId], references: [id])
  school          School       @relation(fields: [schoolId], references: [id])
  installments    Installment[]
}

// Installment - قسط الطالب (ربط الطالب بخطة الرسوم)
model Installment {
  id              String   @id @default(cuid())
  studentId       String
  feePlanId       String
  classId         String
  schoolId        String
  totalAmount     Int                       // المبلغ الإجمالي للقسط (بالدينار)
  paidAmount      Int      @default(0)      // المبلغ المدفوع
  remainingAmount Int                       // المبلغ المتبقي
  discountType    String   @default("none") // نوع الخصم: none, percentage, fixed, free
  discountValue   Int      @default(0)      // قيمة الخصم (نسبة مئوية أو مبلغ ثابت)
  discountNotes   String?                   // ملاحظات الخصم
  status          String   @default("غير مدفوع") // حالة القسط: غير مدفوع، مدفوع جزئياً، مدفوع بالكامل
  dueDate         String?                   // تاريخ الاستحقاق
  notes           String?                   // ملاحظات
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  student         Student   @relation(fields: [studentId], references: [id])
  feePlan         FeePlan   @relation(fields: [feePlanId], references: [id])
  class           Class     @relation(fields: [classId], references: [id])
  school          School    @relation(fields: [schoolId], references: [id])
  payments        Payment[]

  @@unique([studentId, feePlanId])
}

// Payment - الدفعة (دفعة مالية ضمن قسط)
model Payment {
  id              String   @id @default(cuid())
  installmentId   String
  studentId       String
  amount          Int                       // مبلغ الدفعة بالدينار العراقي
  paymentDate     String                    // تاريخ الدفع
  paymentMethod   String   @default("نقدي") // طريقة الدفع: نقدي، تحويل، شيك
  receiptNumber   String?                   // رقم الوصل
  notes           String?                   // ملاحظات
  recordedBy      String?                   // من سجل الدفعة
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  installment     Installment @relation(fields: [installmentId], references: [id])
  student         Student     @relation(fields: [studentId], references: [id])
}

// ==================== SCHEDULE ====================
model ScheduleSlot {
  id        String   @id @default(cuid())
  day       String
  period    Int
  subjectId String
  teacherId String
  classId   String
  sectionId String?
  schoolId  String
  room      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  subject   Subject  @relation(fields: [subjectId], references: [id])
  teacher   Teacher  @relation(fields: [teacherId], references: [id])
  class     Class    @relation(fields: [classId], references: [id])
  school    School   @relation(fields: [schoolId], references: [id])

  @@unique([day, period, teacherId, schoolId])
  @@unique([day, period, classId, sectionId, schoolId])
}

// ==================== USERS & AUTH ====================
model User {
  id        String   @id @default(cuid())
  username  String   @unique
  password  String
  name      String
  role      String   @default("موظف تسجيل")
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
