generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ==================== SCHOOL ====================
model School {
  id              String   @id @default(cuid())
  name            String
  logo            String?
  address         String?
  phone           String?
  email           String?
  principalName   String?
  academicYear    String   @default("2026-2027")
  schoolType      String   @default("ثانوية اعتيادية")
  shiftType       String   @default("صباحي") // صباحي، مسائي، مزدوج
  startTime       String   @default("08:00")
  endTime         String   @default("13:30")
  lateThreshold   Int      @default(10) // minutes
  weekendDays     String   @default("5,6") // Friday=5, Saturday=6
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  students   Student[]
  teachers   Teacher[]
  subjects   Subject[]
  classes    Class[]
  sections   Section[]
  attendance AttendanceRecord[]
  grades     Grade[]
  notices    Notice[]
  activities ActivityLog[]
}

// ==================== CLASSES & SECTIONS ====================
model Class {
  id        String   @id @default(cuid())
  name      String   // الرابع الإعدادي، الخامس العلمي، إلخ
  level     String   // إعدادي
  stage     String   // الرابع، الخامس، السادس
  branch    String?  // علمي، أدبي، أحيائي، تطبيقي
  schoolId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  school    School   @relation(fields: [schoolId], references: [id])
  sections  Section[]
  students  Student[]
  subjects  SubjectClass[]
}

model Section {
  id        String   @id @default(cuid())
  name      String   // أ، ب، ج
  classId   String
  schoolId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  class     Class    @relation(fields: [classId], references: [id])
  school    School   @relation(fields: [schoolId], references: [id])
  students  Student[]
}

// ==================== STUDENTS ====================
model Student {
  id              String   @id @default(cuid())
  studentNumber   String   @unique // STU-2026-00045
  fullName        String
  gender          String   @default("ذكر") // ذكر، أنثى
  dateOfBirth     String?
  nationalId      String?
  phone           String?
  address         String?
  photo           String?
  status          String   @default("مستمر") // مستمر، منقول، تارك، مفصول، متخرج
  qrCode          String?  // QR code data
  cardStatus      String   @default("فعالة") // فعالة، موقوفة، مفقودة، مستبدلة

  classId         String
  sectionId       String
  schoolId        String
  parentId        String?

  guardianName    String?
  guardianPhone   String?
  guardianRelation String?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  class           Class    @relation(fields: [classId], references: [id])
  section         Section  @relation(fields: [sectionId], references: [id])
  school          School   @relation(fields: [schoolId], references: [id])
  parent          Parent?  @relation(fields: [parentId], references: [id])
  attendance      AttendanceRecord[]
  grades          Grade[]
  notes           StudentNote[]
  documents       Document[]
}

// ==================== PARENTS ====================
model Parent {
  id        String   @id @default(cuid())
  name      String
  phone     String
  email     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  children  Student[]
}

// ==================== TEACHERS ====================
model Teacher {
  id          String   @id @default(cuid())
  fullName    String
  phone       String?
  email       String?
  specialty   String?
  status      String   @default("نشط") // نشط، إجازة، منقول، متقاعد
  photo       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  schoolId    String
  school      School   @relation(fields: [schoolId], references: [id])
  subjects    TeacherSubject[]
  classes     TeacherClass[]
  documents   Document[]
}

// ==================== SUBJECTS ====================
model Subject {
  id            String   @id @default(cuid())
  name          String
  code          String   @unique
  type          String   @default("أساسية") // أساسية، اختيارية
  maxScore      Int      @default(100)
  passScore     Int      @default(50)
  schoolId      String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  school        School        @relation(fields: [schoolId], references: [id])
  teachers      TeacherSubject[]
  classes       SubjectClass[]
  grades        Grade[]
  examTypes     ExamType[]
}

model TeacherSubject {
  id        String @id @default(cuid())
  teacherId String
  subjectId String

  teacher   Teacher @relation(fields: [teacherId], references: [id])
  subject   Subject @relation(fields: [subjectId], references: [id])

  @@unique([teacherId, subjectId])
}

model SubjectClass {
  id        String @id @default(cuid())
  subjectId String
  classId   String

  subject   Subject @relation(fields: [subjectId], references: [id])
  class     Class   @relation(fields: [classId], references: [id])

  @@unique([subjectId, classId])
}

model TeacherClass {
  id        String @id @default(cuid())
  teacherId String
  classId   String
  sectionId String?

  teacher   Teacher @relation(fields: [teacherId], references: [id])

  @@unique([teacherId, classId])
}

// ==================== EXAM TYPES ====================
model ExamType {
  id         String   @id @default(cuid())
  name       String   // شهر أول، شهر ثاني، نصف السنة، إلخ
  maxScore   Int
  subjectId  String
  createdAt  DateTime @default(now())

  subject    Subject  @relation(fields: [subjectId], references: [id])
  grades     Grade[]
}

// ==================== ATTENDANCE ====================
model AttendanceRecord {
  id          String   @id @default(cuid())
  studentId   String
  schoolId    String
  date        String   // YYYY-MM-DD
  checkIn     String?  // HH:mm
  checkOut    String?
  status      String   @default("غائب") // حاضر، متأخر، غائب، مستأذن، خروج مبكر، حضور ناقص، إجازة مرضية، إجازة رسمية
  lateMinutes Int?
  earlyExitReason String?
  earlyExitApproved Boolean?
  modifiedBy  String?
  modifiedAt  DateTime?
  createdAt   DateTime @default(now())

  student     Student  @relation(fields: [studentId], references: [id])
  school      School   @relation(fields: [schoolId], references: [id])
}

// ==================== GRADES ====================
model Grade {
  id           String   @id @default(cuid())
  studentId    String
  subjectId    String
  examTypeId   String
  schoolId     String
  score        Float?
  status       String   @default("ناقصة") // مكتملة، ناقصة، غائب، مؤجلة، معاد، مقفلة
  approved     Boolean  @default(false)
  approvedBy   String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  student      Student  @relation(fields: [studentId], references: [id])
  subject      Subject  @relation(fields: [subjectId], references: [id])
  examType     ExamType @relation(fields: [examTypeId], references: [id])
  school       School   @relation(fields: [schoolId], references: [id])
  modifications GradeModification[]

  @@unique([studentId, subjectId, examTypeId])
}

model GradeModification {
  id         String   @id @default(cuid())
  gradeId    String
  oldScore   Float
  newScore   Float
  reason     String
  modifiedBy String
  createdAt  DateTime @default(now())

  grade      Grade    @relation(fields: [gradeId], references: [id])
}

// ==================== STUDENT NOTES ====================
model StudentNote {
  id        String   @id @default(cuid())
  studentId String
  content   String
  type      String   @default("ملاحظة") // ملاحظة، سلوكية، إدارية
  createdBy String
  createdAt DateTime @default(now())

  student   Student  @relation(fields: [studentId], references: [id])
}

// ==================== DOCUMENTS ====================
model Document {
  id        String   @id @default(cuid())
  title     String
  fileUrl   String
  type      String   // صورة شخصية، هوية، شهادة، إلخ
  studentId String?
  teacherId String?
  createdAt DateTime @default(now())

  student   Student? @relation(fields: [studentId], references: [id])
  teacher   Teacher? @relation(fields: [teacherId], references: [id])
}

// ==================== NOTICES ====================
model Notice {
  id        String   @id @default(cuid())
  title     String
  content   String
  type      String   @default("عام") // عام، عاجل، أكاديمي
  schoolId  String
  createdBy String
  createdAt DateTime @default(now())

  school    School   @relation(fields: [schoolId], references: [id])
}

// ==================== USERS & AUTH ====================
model User {
  id        String   @id @default(cuid())
  username  String   @unique
  password  String
  name      String
  role      String   @default("موظف تسجيل") // مدير، معاون، موظف تسجيل، موظف بوابة، مدرس، مسؤول نظام
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ==================== ACTIVITY LOG ====================
model ActivityLog {
  id        String   @id @default(cuid())
  action    String
  details   String?
  userId    String?
  schoolId  String
  createdAt DateTime @default(now())

  school    School   @relation(fields: [schoolId], references: [id])
}
